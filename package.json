    "update:github:win": "scripts\\update-github.bat"
  },
  "dependencies": {
    "@discordjs/rest": "^2.6.1",
    "axios": "^1.15.2",
    "discord.js": "^14.16.0",
    "dotenv": "^17.2.3",
    "express": "^5.1.0",
    "node-cron": "^4.2.1",
    "pg": "^8.11.3",
    "winston": "^3.19.0",
    "winston-daily-rotate-file": "^5.0.0",
    "zod": "^3.25.76"
  },
  "devDependencies": {},
  "engines": {
    "node": ">=20.0.0"
  }
}
